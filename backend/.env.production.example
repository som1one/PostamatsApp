DEBUG=false

DB_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/postamats
ASYNC_DB_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/postamats
REDIS_URL=redis://127.0.0.1:6379/0

JWT_SECRET_KEY=replace-me
JWT_REFRESH_SECRET_KEY=replace-me
ADMIN_JWT_SECRET_KEY=replace-me
ADMIN_JWT_REFRESH_SECRET_KEY=replace-me

WEB_APP_ORIGIN=https://naprokatberu.ru
CORS_ALLOWED_ORIGINS=https://naprokatberu.ru,https://www.naprokatberu.ru
YOOKASSA_RETURN_URL=https://naprokatberu.ru/payment/return
YOOKASSA_DEV_STUB=false

AUTH_CODE_TTL_SECONDS=180
SMS_RU_API_ID=replace-me
SMS_RU_FROM=Naprokat
SMS_RU_TIMEOUT_SECONDS=10

ESI_DEV_STUB=false
ESI_BASE_URL=https://api.esi.bz
ESI_API_KEY=replace-me
ESI_RESERVE_TIMEOUT=15
ESI_WEBHOOK_SECRET=replace-me
ESI_DISCOVERY_TIMEOUT=20
ESI_SNAPSHOT_TIMEOUT=20
ESI_RECONCILE_INTERVAL_SECONDS=60
RETURN_REQUEST_TIMEOUT_SECONDS=1800

UPLOAD_DEV_STUB=false
STORAGE_PROVIDER=filesystem
LOCAL_UPLOAD_ROOT=/app/assets/runtime-uploads
MEDIA_PUBLIC_BASE_URL=
UPLOAD_PRESIGN_EXPIRES=900

# Telegram bot for admin verification notifications.
# 1. Создай бота через @BotFather, получи токен.
# 2. Отправь боту /start со всех аккаунтов, которым нужны уведомления.
# 3. Получи numeric chat_id (например, через @userinfobot) и пропиши через запятую.
# 4. Без токена/chat_id уведомления просто не уходят, эндпоинт продолжает работать.
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_IDS=
TELEGRAM_API_TIMEOUT_SECONDS=10
ADMIN_PANEL_URL=https://api.naprokatberu.ru/admin
